# ---------------------------------------------------------------------------
# Petal & Prosper — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` for local development. On Railway, set these as
# service variables in the dashboard (Postgres-provided vars are injected
# automatically; everything else is your responsibility).
# ---------------------------------------------------------------------------

# Database ------------------------------------------------------------------
# Local: point at your local Postgres.
# Railway: the Postgres plugin sets this automatically via the
# `postgres.railway.internal` host. No action needed in prod.
DATABASE_URL="postgresql://user:password@localhost:5432/petal_and_prosper"

# Auth (NextAuth v5) --------------------------------------------------------
# AUTH_SECRET is used to sign and verify JWT session tokens. Generate with:
#   openssl rand -base64 32
# AUTH_URL must be the canonical URL of the deployed app (no trailing slash).
# NextAuth v5 reads AUTH_SECRET/AUTH_URL first, falling back to the legacy
# NEXTAUTH_SECRET/NEXTAUTH_URL names, so set whichever pair you prefer.
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Optional: public base URL used when generating public proposal links.
# Falls back to the incoming request origin if unset. On Railway, set this
# to your canonical domain so proposal emails link to the right host.
# NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"

# Email ---------------------------------------------------------------------
# Email dispatch is currently STUBBED. `src/lib/email/send.ts` logs every
# outgoing email to stderr and returns success without actually sending.
# Nothing to configure. When we wire SMTP back in we'll document the vars
# here (SMTP_URL, EMAIL_FROM, etc.).
